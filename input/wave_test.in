# equation of state 
gamma           = 1.4

# simulation 
tmax            = 10.0          # 
dtoutput        = 0.01          # 
stepmax         = -1            # unlimitted
CFL             = 0.5           # CFL number ( CFL < 1 ), dt depends on CFL
integrator      = 2             # 1 : forward euler; 2 : rk2; 3: rk3
RcOrder         = 2             # order of spatial reconstruction

# output
dataType        = 0             # 0: output cons; 1: output prim

# domain size 
xmin            = -1.0
xmax            =  1.0
ymin            = -0.5
ymax            =  0.5
zmin            = -0.5
zmax            =  0.5

# mesh 
NX              = 256           # resolution on x   
NY              = 128           # resolution on y 
NZ              = 1             # resolution on z 

NGhost          = 2             # number of ghost cell ( usually is 1 )

# boundary 
# 0: copy, 1: periodic, 2: reflective
xleft           = 2             # 
xright          = 2             # 
yleft           = 1             # 
yright          = 1
zleft           = 1
zright          = 1

# problem setup
rho0            = 1.0           # 
p0              = 1.0           # 
amp             = 0.1          # 
sigma           = 0.1           # 
x0              = 0.0           # 
addVel          = 1             # 