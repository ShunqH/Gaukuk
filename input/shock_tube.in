# equation of state 
gamma           = 1.4           # for adiabatic eos 

# simulation 
tmax            = 0.2           # total time 
stepmax         = -1            # unlimitted
CFL             = 0.5           # CFL number ( CFL < 1 ), dt depends on CFL
integrator      = 2             # 1 : forward euler; 2 : rk2; 3: rk3
RcOrder         = 1             # order of spatial reconstruction

# output
dtoutput        = 0.01             # output every dtoutput
dataType        = 1             # 0: output cons; 1: output prim

# domain size 
xmin            = -0.5 
xmax            = 0.5
ymin            = -0.5
ymax            = 0.5 
zmin            = -0.5
zmax            = 0.5 

# mesh 
NX              = 128           # resolution on x   
NY              = 4           # resolution on y    
NZ              = 4           # resolution on z  
NGhost          = 2             # number of ghost cell ( usually is 1 )

# boundary 
# 0 for copy, 1 for periodic, 2 for reflective
xleft           = 2             
xright          = 2             
yleft           = 1             
yright          = 1             
zleft           = 1             
zright          = 1             

# problem setup
x0              = 0             # center
rhoLeft         = 1.0           # 
pressureLeft    = 1.0           # 
rhoRight        = 0.125         # 
pressureRight   = 0.1           #           
