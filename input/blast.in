# equation of state 
gamma           = 1.4           # for adiabatic eos 

# simulation 
tmax            = 0.1           # total time 
stepmax         = -1            # unlimitted
CFL             = 0.5           # CFL number ( CFL < 1 ), dt depends on CFL
integrator      = 2             # 1 : forward euler; 2 : rk2; 3: rk3
RcOrder         = 2             # order of spatial reconstruction

# output
dtoutput        = 0.002         # output every dtoutput
dataType        = 0             # 0: output cons; 1: output prim

# domain size 
xmin            = -0.5 
xmax            = 0.5
ymin            = -0.5
ymax            = 0.5 
zmin            = -0.5
zmax            = 0.5 

# mesh 
NX              = 256           # resolution on x   
NY              = 256           # resolution on y    
NZ              = 256           # resolution on z  
NGhost          = 2             # number of ghost cell ( usually is 1 )

# boundary 
# 0 for copy, 1 for periodic, 2 for reflective
xleft           = 1             
xright          = 1             
yleft           = 1             
yright          = 1             
zleft           = 1             
zright          = 1             

# problem setup
rho0            = 1 
r0              = 0.05 
eng_tot         = 1 
pressure_low    = 0.1
