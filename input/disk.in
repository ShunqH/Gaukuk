# simulation 
tmax            = 628.31853     # total time 
stepmax         = -1            # -1: unlimitted
CFL             = 0.4           # CFL number ( CFL < 1 ), dt depends on CFL
integrator      = 2             # 1 : forward euler; 2 : rk2; 3: rk3
RcOrder         = 2             # order of spatial reconstruction

# output
dtoutput        = 0.62831853    # output every dtoutput
dataType        = 0             # 0: output cons; 1: output prim

# domain size 
xmin            = -3.2 
xmax            = 3.2 
ymin            = -3.2 
ymax            = 3.2 
zmin            = -0.5
zmax            = 0.5 

# mesh 
NX              = 512           # resolution on x   
NY              = 512           # resolution on y    
NZ              = 1             # resolution on z  
NGhost          = 2             # number of ghost cell 

# boundary 
# 0 for copy, 1 for periodic, 2 for reflective, 3 for outflow
xleft           = 3               
xright          = 3              
yleft           = 3              
yright          = 3              
zleft           = 1              
zright          = 1         

# equation of state 
gamma           = 1.66666667    # for adiabatic eos 

# problem setup
## star 
GM              = 1.0           # note that 2pi in code unit is one yr 
rs              = 0.05           # smoothing length 

## disk
r0              = 1.0           
rho0            = 1.0           # rho(r) = rho0 * (r/r0)^{-p}
p               = 1.0  
cs0             = 0.1           # cs(r) = cs0 * (r/r0)^{-q/2}
q               = 1.0 
         
## Rossby wave instability 
gapWidth        = 0.05          # gap width 
gapDepth        = 0.5           # gap depth (ratio)
amp             = 0.01          # perturbation
km              = 5             # wavenumber


